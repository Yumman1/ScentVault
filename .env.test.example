# ============================================
# ScentVault Automated Test Environment
# Copy this to `.env.test` (gitignored) and fill in.
# ============================================

# ---- DESTRUCTIVE SAFETY SWITCH --------------
# Set to 1 to allow the wipe helpers to DELETE FROM every app table
# (audit_logs, gate_in_logs, gate_out_logs, stock_transfer_logs,
#  perfumes, olfactive_notes, packing_types, locations, customers,
#  suppliers). Auth users and profiles are NEVER touched.
# If this is not "1", tests refuse to run.
TESTS_ALLOW_WIPE=1

# ---- Supabase connection (same project the app uses) ----
# Use a single = only (not VITE_SUPABASE_URL==https://... — that breaks the client).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Test users -----------------------------
# An existing Admin (required). Must have role='Admin' in profiles.
TEST_ADMIN_EMAIL=admin@scentvault.test
TEST_ADMIN_PASSWORD=change-me-admin

# Optional Operator and Viewer accounts used by the RLS matrix tests.
# If omitted, RLS tests that require those roles are skipped.
TEST_OPERATOR_EMAIL=operator@scentvault.test
TEST_OPERATOR_PASSWORD=change-me-operator

TEST_VIEWER_EMAIL=viewer@scentvault.test
TEST_VIEWER_PASSWORD=change-me-viewer

# ---- Playwright target ----------------------
APP_URL=http://localhost:3000
