# ScentVault Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials

# --- Local UI testing (optional): fixed login without Supabase — DO NOT use in production ---
VITE_DEV_AUTH_BYPASS=false
# When true, sign in with:
VITE_DEV_LOGIN_EMAIL=dev@scentvault.local
VITE_DEV_LOGIN_PASSWORD=scentvault123

# Supabase Configuration (Required for real data / production)
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# After the first user signs up, promote them to Admin (Supabase → SQL Editor):
# UPDATE public.profiles SET role = 'Admin', can_view_prices = true
# WHERE id = (SELECT id FROM auth.users ORDER BY created_at ASC LIMIT 1);

# Apply database schema: copy/run files in supabase/migrations in order (001, 002, 003, 004),
# or use Supabase CLI: supabase db push / link
